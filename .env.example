# JARVIS Skills / MCP Server Configuration
# Copy this to .env and fill in your values

# Server Configuration
MCP_PORT=5050
LOG_LEVEL=INFO
RUST_MCP_HOST=127.0.0.1
RUST_MCP_PORT=5050

# Spotify Integration 
# Get credentials: https://developer.spotify.com/dashboard
SPOTIPY_CLIENT_ID=your-spotify-client-id
SPOTIPY_CLIENT_SECRET=your-spotify-client-secret
SPOTIPY_REDIRECT_URI=http://localhost:8888/callback

# Security: Allowed roots for file operations (semicolon-separated)
# The server automatically allows your Downloads, Documents, Desktop, and Home folders.
# Use this variable only if you want to restrict access to SPECIFIC paths 
# or add additional drives (e.g., D:\Music or /mnt/data).
# Example (Windows): JARVIS_SKILLS_ALLOWED_ROOTS=C:\CustomFolder;D:\Projects
# Example (Linux): JARVIS_SKILLS_ALLOWED_ROOTS=/home/user/custom;/media/data

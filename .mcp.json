{
  "mcpServers": {
    "jarvis-skills": {
      "type": "local",
      "command": "rust-mcp-server/target/release/jarvis-rust-mcp-server.exe",
      "args": [
        "--stdio"
      ],
      "tools": [
        "*"
      ]
    },
    "spotify": {
      "type": "local",
      "command": "node",
      "args": [
        "spotify-mcp-server/build/index.js"
      ],
      "tools": [
        "*"
      ]
    }
  }
}
